NEXT_PUBLIC_SITE_URL=http://localhost:4173
NEXT_PUBLIC_ADMIN_ORIGIN=https://admin.mixtapemosaic.com

# Cloudflare Access admin gate
CLOUDFLARE_ACCESS_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_ACCESS_ALLOWED_EMAILS=trevin@mixtapemosaic.com
ALLOW_LOCAL_ADMIN=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 customizer artwork library
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ORIGINALS_BUCKET_NAME=mixtape-mosaic-artwork-originals
R2_DERIVATIVES_BUCKET_NAME=mixtape-mosaic-artwork-images
R2_CUSTOMER_UPLOADS_BUCKET_NAME=mixtape-mosaic-artwork-originals
R2_PUBLIC_IMAGE_BASE_URL=https://artworkimages.mixtapemosaic.com

# OpenAI metadata generation for admin artwork uploads
OPENAI_API_KEY=
OPENAI_IMAGE_METADATA_MODEL=gpt-4.1-mini
OPENAI_IMAGE_METADATA_PROMPT_ID=
OPENAI_IMAGE_METADATA_PROMPT_VERSION=

# Stripe test mode
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_REVALIDATE_SECRET=
